#!/usr/bin/env bash
# ctx — client context switcher v3.2.0
# https://github.com/Hei-Tech-Inc/ctx

set -uo pipefail

# ─── Locate libs ──────────────────────────────────────────────────────────────
CTX_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CTX_LIB="$(cd "$CTX_BIN/../lib" 2>/dev/null && pwd || echo "$CTX_BIN")" # install.sh replaces this line when installing

[[ -f "$CTX_LIB/core.sh"       ]] || CTX_LIB="$CTX_BIN"
[[ -f "$CTX_LIB/core.sh"       ]] || { echo "ctx: cannot find lib/core.sh" >&2; exit 1; }

# shellcheck source=../lib/core.sh
source "$CTX_LIB/core.sh"
# shellcheck source=../lib/cmd_import.sh
source "$CTX_LIB/cmd_import.sh"
# shellcheck source=../lib/cmd_ops.sh
source "$CTX_LIB/cmd_ops.sh"

# ─── Flag parsing ─────────────────────────────────────────────────────────────
CTX_DRY_RUN=0
CTX_QUIET=0
CTX_JSON=0
POSITIONAL=()

for arg in "$@"; do
  case "$arg" in
    --dry-run)    CTX_DRY_RUN=1 ;;
    --quiet|-q)   CTX_QUIET=1 ;;
    --no-gum)     HAS_GUM=false ;;
    --json)       CTX_JSON=1 ;;
    *)            POSITIONAL+=("$arg") ;;
  esac
done
export CTX_DRY_RUN CTX_QUIET CTX_JSON HAS_GUM
set -- "${POSITIONAL[@]+"${POSITIONAL[@]}"}"

# ─── Help ─────────────────────────────────────────────────────────────────────
cmd_help() {
  case "${1-}" in
    setup|import|add|wizard)
      cmd_setup_help
      return 0
      ;;
  esac
  if $HAS_GUM; then
    gum style --border rounded --border-foreground 99 \
      --padding "1 3" --margin "1 0" \
      "$(gum style --bold "ctx v${CTX_VERSION}") — client context switcher" \
      "" \
      "$(gum style --faint "SETUP")" \
      "  init             Check deps, install hooks" \
      "  setup            Configure a new client profile (see: --config FILE)" \
      "  import / add     Alias for setup" \
      "" \
      "$(gum style --faint "DAILY USE")" \
      "  use  <name>      Activate a profile" \
      "  deactivate       Clear active profile (prints eval for your shell)" \
      "  list             List all profiles" \
      "  status           Active profile + live checks" \
      "  clone            git clone with GitHub host rewrite for this profile" \
      "  workdir-prompt   Print work_dir='WORK_DIR=…' when cwd is in prompt scope (for PS1)" \
      "" \
      "$(gum style --faint "SECRETS  (Keychain or ~/.ctx/secrets)")" \
      "  secret set   <profile> <KEY>" \
      "  secret get   <profile> <KEY>" \
      "  secret list  <profile>" \
      "  secret delete <profile> <KEY>" \
      "" \
      "$(gum style --faint "MAINTENANCE")" \
      "  config [show]    Show ctx config values" \
      "  config work-root Set default client directory root" \
      "  config export    Export portable config bundle (no secrets)" \
      "  config import    Import portable config bundle" \
      "  verify [name]    One profile: live ssh -T, gh match, paths, email" \
      "  edit   <name>    Open profile in \$EDITOR" \
      "  remove <name>    Delete profile + secrets" \
      "  undo             Restore last backup" \
      "  install-hook     Install mise + ctx hooks into shell rc" \
      "  upgrade [--check] Re-run installer, or check for newer version" \
      "  uninstall [--purge] Remove ctx install; optional ~/.ctx wipe" \
      "  doctor           Machine-wide: tools, hooks, SSH layout, profiles" \
      "  version          Print version" \
      "  help setup       Full setup wizard + --config reference" \
      "" \
      "$(gum style --faint "FLAGS")" \
      "  --dry-run        Preview changes without writing files" \
      "  --quiet          Suppress output (used by auto-switch)" \
      "  --no-gum         Force plain text prompts" \
      "  --json           Machine-readable JSON (list, status)" \
      "" \
      "$(gum style --faint "SETUP FLAGS")" \
      "  --config FILE    Non-interactive wizard (see examples/setup.noninteractive.conf.example)" \
      "  -y / --yes       With --config: skip final confirmation prompt" \
      "  setup --help     Same as: ctx help setup"
  else
    cat <<EOF

${BOLD}ctx${RESET} — client context switcher v${CTX_VERSION}

${BOLD}SETUP${RESET}
  init                  Check deps, install hooks
  setup                 Configure a new profile (optional: --config FILE -y)
  import / add          Alias for setup

${BOLD}DAILY USE${RESET}
  use  <name>           Activate a profile (gh, SSH, AWS, Azure, GCP, kubectl)
  deactivate            Clear active profile from ~/.ctx/config; run eval \"\$(ctx deactivate)\"
  list                  List all profiles
  status                Active profile + live checks
  clone                 git clone with GitHub host rewrite (see README)
  workdir-prompt        Print work_dir='WORK_DIR=…' when cwd is in prompt scope (for PS1)

${BOLD}SECRETS  (macOS Keychain; Linux: ~/.ctx/secrets, 0600 — encrypt disk)${RESET}
  secret set   <profile> <KEY>
  secret get   <profile> <KEY>
  secret list  <profile>
  secret delete <profile> <KEY>

${BOLD}MAINTENANCE${RESET}
  help setup            Full setup wizard + --config reference
  config [show]         Show ctx config values
  config work-root <p>  Set default client directory root
  config export <dir>   Export config for laptop migration (no secrets)
  config import <dir>   Import config bundle on a new machine
  verify [name]         One profile: live ssh -T, gh match, paths, email
  edit   <name>         Open profile config in \$EDITOR
  remove <name>         Delete profile + stored secrets
  undo                  Restore last backup
  install-hook [rc]     Install mise + ctx hooks into shell rc
  upgrade [--check]     Re-run installer, or compare to latest on main
  uninstall [--purge]   Remove ctx binary + lib; --purge deletes ~/.ctx
  doctor                Machine-wide: tools, hooks, SSH layout, all profiles
  completion <zsh|bash|fish> Print shell completion script
  version               Print version

${BOLD}FLAGS${RESET}
  --dry-run             Preview changes, write nothing
  --quiet               Suppress output (auto-switch hook uses this)
  --no-gum              Force plain text prompts
  --json                Machine-readable JSON for supported commands (list, status)
  setup --config FILE   Non-interactive wizard (KEY=value file)
  setup -y              With --config: confirm without prompting
  setup --help          Same as: ctx help setup

${BOLD}SETUP CONFIG FILE${RESET}
  See ${BOLD}examples/setup.noninteractive.conf.example${RESET} in the repo.
  1. ctx setup           → wizard detects your existing keys/accounts
  2. ctx writes:
     - ~/.ctx/profiles/<name>.conf   (metadata)
     - ~/.config/git/ctx-<name>      (git identity)
     - ~/.gitconfig                  (one includeIf line, deduped)
     - ~/.ssh/ctx_config             (SSH hosts — never ~/.ssh/config)
     - ~/clients/<name>/mise.toml    (env vars + hooks, auto-loads on cd)
  3. Secrets → macOS Keychain (or ~/.ctx/secrets elsewhere), loaded by mise hooks.enter

${BOLD}INSTALL REQUIREMENTS${RESET}
  Everything is installed by install.sh:
    mise (env/tools per dir), gum (TUI), gh (GitHub auth), git, awscli

EOF
  fi
}

# ─── Shell completions ────────────────────────────────────────────────────────
cmd_completion() {
  local shell="${1:-zsh}"
  case "$shell" in
    zsh) cat <<'ZSH'
#compdef ctx
_ctx() {
  local cmds profiles
  cmds=(
    'init:Check deps, install hooks'
    'setup:Configure a new profile'
    'import:Alias for setup'
    'add:Alias for setup'
    'use:Activate a profile'
    'deactivate:Clear active profile (shell eval)'
    'list:List all profiles'
    'status:Show active profile and live checks'
    'clone:git clone with GitHub host rewrite'
    'workdir-prompt:Print WORK_DIR line when cwd is in prompt scope'
    'config:Configure ctx defaults'
    'secret:Manage profile secrets'
    'verify:Verify profile wiring'
    'edit:Open profile config in $EDITOR'
    'remove:Delete a profile'
    'undo:Restore last backup'
    'install-hook:Install shell hooks'
    'upgrade:Update ctx via installer'
    'uninstall:Remove ctx install'
    'doctor:Health check'
    'completion:Print shell completion'
    'version:Print version'
    'help:Show help'
  )
  profiles=("${(@f)$(ctx list 2>/dev/null | grep '^  [a-z]' | awk '{print $1}')}")
  local setup_flags=(
    '--config:Non-interactive KEY=value file'
    '-y:Skip final confirm'
    '--yes:Skip final confirm'
    '--help:Full setup reference'
    '-h:Full setup reference'
  )
  local help_topics=('setup:Wizard and --config reference')
  local global_flags=(
    '--dry-run:Preview without writing files'
    '--quiet:Suppress output'
    '--no-gum:Plain prompts'
    '--json:JSON output (list, status)'
  )
  case $CURRENT in
    2) _describe 'ctx flags' global_flags && _describe 'ctx commands' cmds ;;
    3)
      case ${words[2]} in
        --dry-run|--quiet|--no-gum|--json) _describe 'ctx commands' cmds ;;
        use|edit|remove|verify) _describe 'profiles' profiles ;;
        setup|import|add) _describe 'setup options' setup_flags ;;
        help) _describe 'help topics' help_topics ;;
        secret) local sub=('set' 'get' 'list' 'delete' 'migrate'); _describe 'subcommands' sub ;;
        config) local sub=('show' 'work-root' 'secret-provider' 'prompt-workdir-depth' 'prompt-extra-paths' 'export' 'import'); _describe 'subcommands' sub ;;
        upgrade) local sub=('--check'); _describe 'upgrade flags' sub ;;
        uninstall) local sub=('--purge'); _describe 'uninstall flags' sub ;;
        completion) local sh=('zsh' 'bash' 'fish'); _describe 'shells' sh ;;
      esac ;;
    4)
      case ${words[2]} in
        secret) _describe 'profiles' profiles ;;
        setup|import|add)
          if [[ ${words[3]} == --config ]]; then
            _files
          else
            _describe 'setup options' setup_flags
          fi
          ;;
        clone)
          case ${words[3]} in
            -p|--profile) _describe 'profiles' profiles ;;
          esac
          ;;
      esac
      ;;
    5)
      case ${words[2]} in
        setup|import|add) _describe 'setup options' setup_flags ;;
        secret)
          [[ ${words[3]} =~ ^(set|get|delete)$ ]] && _describe 'profiles' profiles
          ;;
      esac
      ;;
  esac
}
_ctx "$@"
ZSH
    ;;
    bash) cat <<'BASH'
_ctx_comp() {
  local cur="${COMP_WORDS[COMP_CWORD]}" prev="${COMP_WORDS[COMP_CWORD-1]}"
  local cmds="init setup import add use deactivate list status clone workdir-prompt config secret verify edit remove undo install-hook upgrade uninstall doctor completion version help"
  local profiles; profiles=$(ctx list 2>/dev/null | grep '^  [a-z]' | awk '{print $1}' | tr '\n' ' ')
  local w1="${COMP_WORDS[1]-}"
  # ctx list|status [--json]
  if [[ "$w1" =~ ^(list|status)$ && "$prev" == "$w1" ]]; then
    COMPREPLY=($(compgen -W "--json" -- "$cur"))
    return
  fi
  # ctx setup [--config FILE] [-y|--yes]
  if [[ "$w1" =~ ^(setup|import|add)$ ]]; then
    if [[ "$prev" == "--config" ]]; then
      COMPREPLY=($(compgen -f -- "$cur"))
      return
    fi
    COMPREPLY=($(compgen -W "--config -y --yes --help -h" -- "$cur"))
    return
  fi
  if [[ "$prev" == "help" ]]; then
    COMPREPLY=($(compgen -W "setup" -- "$cur"))
    return
  fi
  case "$prev" in
    use|edit|remove|verify) COMPREPLY=($(compgen -W "$profiles" -- "$cur")) ;;
    clone) COMPREPLY=($(compgen -W "-p --profile" -- "$cur")) ;;
    secret) COMPREPLY=($(compgen -W "set get list delete migrate" -- "$cur")) ;;
    config) COMPREPLY=($(compgen -W "show work-root secret-provider prompt-workdir-depth prompt-extra-paths export import" -- "$cur")) ;;
    upgrade) COMPREPLY=($(compgen -W "--check" -- "$cur")) ;;
    uninstall) COMPREPLY=($(compgen -W "--purge" -- "$cur")) ;;
    completion) COMPREPLY=($(compgen -W "zsh bash fish" -- "$cur")) ;;
    ctx) COMPREPLY=($(compgen -W "$cmds --dry-run --quiet --no-gum --json" -- "$cur")) ;;
  esac
  if [[ ${COMP_WORDS[1]} == clone && ${COMP_WORDS[COMP_CWORD-2]} == @(-p|--profile) ]]; then
    COMPREPLY=($(compgen -W "$profiles" -- "$cur"))
  fi
  if [[ ${COMP_WORDS[1]} == secret && ${COMP_WORDS[COMP_CWORD-1]} =~ ^(set|get|delete)$ ]]; then
    COMPREPLY=($(compgen -W "$profiles" -- "$cur"))
  fi
}
complete -F _ctx_comp ctx
BASH
    ;;
    fish) cat <<'FISH'
function __fish_ctx_profiles
    ctx list 2>/dev/null | awk '/^  [a-z]/ {print $1}'
end

complete -c ctx -f

complete -c ctx -n '__fish_use_subcommand' -l json -d 'JSON output (list, status)'

complete -c ctx -n '__fish_use_subcommand' -a 'init setup import add use deactivate list status clone workdir-prompt config secret verify edit remove undo install-hook upgrade uninstall doctor completion version help'

complete -c ctx -n '__fish_seen_subcommand_from ctx help' -a 'setup' -d 'Wizard and --config reference'

complete -c ctx -n '__fish_seen_subcommand_from ctx use' -a '(__fish_ctx_profiles)'
complete -c ctx -n '__fish_seen_subcommand_from ctx edit' -a '(__fish_ctx_profiles)'
complete -c ctx -n '__fish_seen_subcommand_from ctx remove' -a '(__fish_ctx_profiles)'
complete -c ctx -n '__fish_seen_subcommand_from ctx verify' -a '(__fish_ctx_profiles)'

complete -c ctx -n '__fish_seen_subcommand_from ctx secret' -a 'set get list delete migrate'
complete -c ctx -n '__fish_seen_subcommand_from ctx secret set' -a '(__fish_ctx_profiles)'
complete -c ctx -n '__fish_seen_subcommand_from ctx secret get' -a '(__fish_ctx_profiles)'
complete -c ctx -n '__fish_seen_subcommand_from ctx secret delete' -a '(__fish_ctx_profiles)'

complete -c ctx -n '__fish_seen_subcommand_from ctx config' -a 'show work-root secret-provider prompt-workdir-depth prompt-extra-paths export import'
complete -c ctx -n '__fish_seen_subcommand_from ctx upgrade' -a '--check'
complete -c ctx -n '__fish_seen_subcommand_from ctx uninstall' -a '--purge'
complete -c ctx -n '__fish_seen_subcommand_from ctx completion' -a 'zsh bash fish'

complete -c ctx -n '__fish_seen_subcommand_from ctx setup import add' -s y -l yes -d 'Skip final review confirm'
complete -c ctx -n '__fish_seen_subcommand_from ctx setup import add' -s h -l help -d 'Full setup reference'
complete -c ctx -n '__fish_seen_subcommand_from ctx setup import add' -l config -d 'Non-interactive KEY=value file' -r
complete -c ctx -n '__fish_seen_subcommand_from ctx setup import add; and __fish_prev_arg_in --config' -f -a '(__fish_complete_path)'

complete -c ctx -n '__fish_seen_subcommand_from ctx list' -l json -d 'JSON output'
complete -c ctx -n '__fish_seen_subcommand_from ctx status' -l json -d 'JSON output'

complete -c ctx -n '__fish_seen_subcommand_from ctx clone' -s p -l profile -d 'Profile' -a '(__fish_ctx_profiles)'
FISH
    ;;
    *) die "Unknown shell: $shell. Supported: zsh, bash, fish" ;;
  esac
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)             cmd_init ;;
    setup|import|add) cmd_import "$@" ;;
    use)              cmd_use "${1:-}" ;;
    deactivate)      cmd_deactivate "$@" ;;
    list|ls)          cmd_list ;;
    status|st)        cmd_status ;;
    clone)            cmd_clone "$@" ;;
    workdir-prompt)   cmd_workdir_prompt ;;
    config)           cmd_config "$@" ;;
    secret)           cmd_secret "$@" ;;
    verify)           cmd_verify "${1:-}" ;;
    edit)
      local pname="${1:-}"
      [[ -z "$pname" ]] && die "Usage: ctx edit <profile>"
      profile_exists "$pname" || die "Profile '$pname' not found."
      "${EDITOR:-nano}" "$CTX_PROFILES_DIR/${pname}.conf"
      ;;
    remove|rm|del)    cmd_remove "${1:-}" ;;
    undo)             cmd_undo ;;
    install-hook)     cmd_install_hook "${1:-}" ;;
    upgrade)          cmd_upgrade "$@" ;;
    uninstall)        cmd_uninstall "$@" ;;
    doctor)           cmd_doctor ;;
    completion)       cmd_completion "${1:-zsh}" ;;
    version|-v|--version) echo "ctx version $CTX_VERSION" ;;
    help|-h|--help)   cmd_help "$@" ;;
    *)
      error "Unknown command: $cmd"
      echo ""
      echo "  Run 'ctx help' for usage."
      echo ""
      exit 1
      ;;
  esac
}

main "$@"
