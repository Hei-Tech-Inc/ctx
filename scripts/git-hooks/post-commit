#!/bin/sh
# If the IDE appended a coding-agent co-author line after other hooks, strip it from HEAD (same tree).
case "${GIT_HOOK_AGENT_POST:-}" in 1) exit 0 ;; esac

msg=$(git log -1 --format=%B 2>/dev/null) || exit 0
echo "$msg" | grep -qiE 'cursoragent|co-authored-by:.*(cursoragent|@cursor\.com|anthropic|noreply@anthropic|openai|chatgpt|gemini|codeium|windsurf|copilot|cursor[[:space:]]*<|claude[[:space:]]+(sonnet|opus|haiku))' || exit 0

root="$(git rev-parse --show-toplevel)"
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT INT HUP
git log -1 --format=%B | perl "$root/scripts/git-history-strip-agent-trailers.pl" > "$tmp"

export GIT_HOOK_AGENT_POST=1
GIT_COMMITTER_DATE=$(git log -1 --format=%cI)
export GIT_COMMITTER_DATE
git commit --amend -F "$tmp" --no-edit >/dev/null 2>&1 || true
trap - EXIT INT HUP
rm -f "$tmp"
