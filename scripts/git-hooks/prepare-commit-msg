#!/bin/sh
# Strip coding-agent Co-authored-by lines before the commit is recorded (IDEs may inject them).
# Same patterns as scripts/git-history-strip-agent-trailers.pl and CI git-history-hygiene.
# Enable: ./scripts/install-git-hooks.sh
set -e
msg_file="${1:?}"
root="$(git rev-parse --show-toplevel)"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT INT HUP
perl "$root/scripts/git-history-strip-agent-trailers.pl" < "$msg_file" > "$tmp"
mv "$tmp" "$msg_file"
trap - EXIT INT HUP
