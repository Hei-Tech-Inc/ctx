#!/bin/sh
# Strip automation co-author lines that mention Cursor before the message is finalized.
# Pair with commit-msg (blocks any remaining 'cursor' substring).
# Enable: git config core.hooksPath scripts/git-hooks
set -e
msg_file="${1:?}"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT INT HUP
perl -0777 -pe 's/^Co-authored-by:.*cursor.*\n//gmi' "$msg_file" > "$tmp"
mv "$tmp" "$msg_file"
trap - EXIT INT HUP
